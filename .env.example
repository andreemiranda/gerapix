# =====================================================
# PIXFLOW — Template de Variáveis de Ambiente
# Copie este arquivo para .env.development e .env.production
# NUNCA commite arquivos .env com valores reais
# =====================================================

# --- Firebase Configuration ---
VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id
VITE_FIREBASE_DATABASE_ID=(default)

# --- App Configuration ---
VITE_APP_NAME=GeraPix
VITE_APP_URL=http://localhost:3000
VITE_APP_ENV=development

# --- Security ---
VITE_RECAPTCHA_SITE_KEY=6Ldzos8sAAAAAIsulnq31l-BfDwjroqr3eniO7cN
RECAPTCHA_SECRET_KEY=6Ldzos8sAAAAAIaisiimZHQpzXYm6NRws44uoLd0

# --- Feature Flags ---
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_PWA=true
